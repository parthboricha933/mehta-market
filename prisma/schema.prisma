// Prisma schema for Mehta Super Market, Rajula

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Use a separate schema to avoid conflicts with other projects sharing this Neon DB.
  // Postgres schemas are like namespaces — they keep our tables isolated.
  schemas = ["mehta_market"]
}

// All models live in the mehta_market schema (set via @@schema below).
// This isolates them from other projects using the same Neon database.

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@schema("mehta_market")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  icon      String?
  products  Product[]
  createdAt DateTime  @default(now())

  @@schema("mehta_market")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  mrp         Float?
  unit        String?
  images      String   // JSON array of image URLs
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  soldCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]

  @@schema("mehta_market")
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerName  String
  mobile        String
  address       String
  landmark      String?
  notes         String?
  items         OrderItem[]
  subtotal      Float
  deliveryCharge Float
  total         Float
  status        String      @default("PENDING") // PENDING, ACCEPTED, REJECTED, DELIVERED
  // Coupon fields (nullable — most orders won't have a coupon)
  couponCode    String?
  couponDiscount Float?     @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@schema("mehta_market")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int
  image     String?

  @@schema("mehta_market")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON encoded value
  updatedAt DateTime @updatedAt

  @@schema("mehta_market")
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  description     String?
  // Discount type: "FIXED" (₹ off) or "PERCENTAGE" (% off)
  discountType    String   @default("FIXED")
  // For FIXED: the amount in ₹ to subtract. For PERCENTAGE: the percentage (0-100).
  discountValue   Float
  // Minimum order subtotal required for the coupon to apply
  minOrderValue   Float    @default(0)
  // Maximum number of times this coupon can be used (0 = unlimited)
  maxUsage        Int      @default(0)
  // Current usage count
  usageCount      Int      @default(0)
  // Expiry date (null = never expires)
  expiryDate      DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@schema("mehta_market")
}

model PushSubscription {
  id            String   @id @default(cuid())
  // The admin user who owns this subscription
  adminId       String
  // Web Push subscription endpoint URL
  endpoint      String
  // Subscription expiration time (nullable)
  expirationTime DateTime?
  // JSON-encoded keys object (p256dh, auth)
  keys          String
  createdAt     DateTime @default(now())

  @@unique([adminId, endpoint])
  @@schema("mehta_market")
}
